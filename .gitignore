# =============================================================================
# .gitignore — Ecommerce with AI Integration
# Stack: React + Vite (client) | Node/Express (server) | Python ML (ml-service)
# =============================================================================


# =============================================================================
# NODE — Dependencies
# =============================================================================
node_modules/
**/node_modules/
.npm/
.yarn/
.pnp.*


# =============================================================================
# NODE — Build Outputs
# =============================================================================
dist/
build/
out/
**/dist/
**/build/
client/.vite/
**/.vite/


# =============================================================================
# NODE — Logs
# =============================================================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*
pids/
*.pid
*.seed
*.pid.lock


# =============================================================================
# NODE — Runtime & Cache
# =============================================================================
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
*.tsbuildinfo
.node_repl_history


# =============================================================================
# ENVIRONMENT VARIABLES (never commit secrets!)
# =============================================================================
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example
!.env.*.example
server/.env
ml-service/.env
client/.env
client/.env.*
!client/.env.example


# =============================================================================
# PYTHON — Bytecode & Cache
# =============================================================================
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python


# =============================================================================
# PYTHON — Virtual Environments
# =============================================================================
venv/
.venv/
env/
ENV/
ml-service/venv/
ml-service/.venv/
ml-service/env/


# =============================================================================
# PYTHON — Distribution / Packaging
# =============================================================================
*.egg
*.egg-info/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
wheels/
*.whl
MANIFEST


# =============================================================================
# PYTHON — Testing & Coverage
# =============================================================================
.pytest_cache/
**/.pytest_cache/
.coverage
.coverage.*
coverage.xml
*.cover
htmlcov/
.tox/
.nox/
nosetests.xml
test-results/


# =============================================================================
# PYTHON — Type Checking & Linting
# =============================================================================
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.pytype/


# =============================================================================
# PYTHON — Jupyter Notebooks
# =============================================================================
.ipynb_checkpoints/
*.ipynb_checkpoints


# =============================================================================
# ML / AI — Models & Data
# =============================================================================
*.h5
*.hdf5
*.pkl
*.pickle
*.joblib
*.pt
*.pth
*.onnx
*.bin
*.safetensors
checkpoints/
model_weights/
saved_models/
ml-service/models/*.pkl
ml-service/models/*.h5


# =============================================================================
# DATABASE
# =============================================================================
*.db
*.sqlite
*.sqlite3
mongod.lock
*.dump
dump/


# =============================================================================
# OS — macOS
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride
Icon


# =============================================================================
# OS — Windows
# =============================================================================
Thumbs.db
thumbs.db
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
*.cab
*.msi
*.msix
*.msm
*.msp


# =============================================================================
# OS — Linux
# =============================================================================
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*


# =============================================================================
# EDITORS — VS Code
# =============================================================================
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example
*.code-workspace


# =============================================================================
# EDITORS — JetBrains (WebStorm, PyCharm, etc.)
# =============================================================================
.idea/
*.iml
*.iws
*.ipr


# =============================================================================
# EDITORS — Misc
# =============================================================================
*.swp
*.swo
*.bak
*.tmp
*.orig
*.rej
*_conflict-*


# =============================================================================
# UPLOADS & GENERATED MEDIA
# =============================================================================
uploads/
public/uploads/
static/uploads/
*.temp


# =============================================================================
# CERTIFICATES & KEYS
# =============================================================================
*.pem
*.key
*.crt
*.csr
*.p12
*.pfx
*.jks
secrets/
.secrets/


# =============================================================================
# DEPLOYMENT (keep local, don't push)
# =============================================================================
.vercel/
.netlify/
.serverless/
.terraform/
*.tfstate
*.tfstate.*


# =============================================================================
# MISCELLANEOUS
# =============================================================================
tmp/
temp/
**/.tailwindcss/
**/client/.vite/
